# AI
OPENROUTER_API_KEY=

# Messaging — Discord
DISCORD_WEBHOOK_URL=          # 시연 전용 분리 Discord 서버 webhook
DISCORD_INTERNAL_WEBHOOK_URL= # (선택) 사내 NDA 채널 — 시연 사용 금지

# Messaging — Email (Phase 2 case03)
GMAIL_OAUTH_CREDENTIALS=./secrets/gmail_oauth.json
GMAIL_TOKEN_PATH=./secrets/gmail_token.json
GMAIL_SENDER=                 # e.g., "AX상사 <sales@ax-corp.example.com>"
SMTP_HOST=                    # 폴백용 — Gmail OAuth 미설정 시 SMTP 사용
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# OCR (Phase 2 case07/08) — MLX (mlx_vlm.server) backend.
# 모두 비워두면 runner.py가 두 mlx_vlm.server 인스턴스를 subprocess로 자동 spawn
# (E2B 11437, E4B 11438) 하고, runner 종료 시 process group SIGTERM→SIGKILL로 회수한다.
# 외부에서 항상 띄워두는 운영(plist 등)을 쓰면 base_url을 명시 — runner는 spawn을 건너뛴다.
AX_OCR_BASE_URL_E2B=          # 예: http://127.0.0.1:11437/v1 (설정 시 spawn 스킵)
AX_OCR_BASE_URL_E4B=          # 예: http://127.0.0.1:11438/v1 (설정 시 spawn 스킵)
AX_MLX_BIN=                   # 기본: /Users/jerome/mlx-env/bin/mlx_vlm.server
AX_GEMMA_E2B_MODEL_PATH=      # 기본: /Users/jerome/models/gemma-4-e2b-mlx
AX_GEMMA_E4B_MODEL_PATH=      # 기본: /Users/jerome/models/gemma-4-e4b-mlx

# docgen 스킬 경로 override (Phase 2 case05/06)
AX_MD_TO_PDF_DIR=             # 기본: /Users/jerome/.claude/skills/md-to-pdf
AX_MD_TO_PDF_SCRIPT=          # 기본: scripts/md-to-pdf.ts
AX_MD_TO_PDF_TIMEOUT=         # 기본: 60 (초)
AX_HWPX_EDITOR_DIR=           # 기본: /Users/jerome/.claude/skills/hwpx-editor/scripts
